# subgen bootstrap config. Copy to `.env` in this folder and fill it in.
#   cp .env.example .env
# `.env` is gitignored — never commit the real file.
#
# Only operational data (nodes, rules, rule-providers, base YAML) lives in the
# SQLite store and is edited via the admin panel. Everything below is bootstrap.

# REQUIRED. HMAC key for /sub/{token} links and admin sessions.
#   openssl rand -hex 32
# Rotating it invalidates every subscription link and logs admins out.
SUBGEN_SECRET=

# Admin panel. Empty password disables the panel.
SUBGEN_ADMIN_USER=admin
SUBGEN_ADMIN_PASSWORD=

# Listener. Use 0.0.0.0:2097 in production, 127.0.0.1:2097 locally.
SUBGEN_LISTEN=127.0.0.1:2097

# TLS. Set both for HTTPS; leave BOTH empty to serve plain HTTP (local dev).
SUBGEN_TLS_CERT=
SUBGEN_TLS_KEY=

# External base URL written into subscription links (scheme+host+port, no path).
SUBGEN_PUBLIC_BASE=http://127.0.0.1:2097

# SQLite path. Default db/subgen.db (relative to the working directory).
#SUBGEN_DB_PATH=db/subgen.db

# Serve the admin UI (CSS/JS/SPA) live from this on-disk dir instead of the copy
# embedded in the binary — edit + browser-reload, no Go rebuild. Path is relative
# to the working directory. Leave empty in production (uses the embedded assets).
# For local dev (`go run ./cmd/service` from subgen/):
#SUBGEN_STATIC_DIR=internal/handlers/web/static

# Subscription-profile knobs (title, filename, update interval) are NOT env vars —
# they are per-config settings edited in the admin "Config" tab (stored in the DB).
